{
  "name": "git-repository-list",
  "version": "1.0.0",
  "description": "Git repository list",
  "keywords": [
    "extensions",
    "Azure DevOps",
    "Visual Studio Team Services"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "package": "npm run build && tfx extension create --manifest-globs azure-devops-extension.json"
  },
  "dependencies": {
    "azure-devops-extension-api": "^4.0.3",
    "azure-devops-extension-sdk": "^4.0.2",
    "azure-devops-ui": "^2.272.0",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^16.14.69",
    "@types/react-dom": "^16.9.25",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.1",
    "rimraf": "~2.6.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "sass": "^1.89.0",
    "sass-loader": "^13.0.0",
    "style-loader": "^4.0.0",
    "tfx-cli": "^0.6.3",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "typescript": "^6.0.3",
    "webpack": "^5.91.0",
    "webpack-cli": "^7.0.2"
  }
